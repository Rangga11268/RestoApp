APP_NAME="RestoApp"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------
# Database — MySQL
# -----------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=restosaas
DB_USERNAME=root
DB_PASSWORD=

# -----------------------------------------------
# Session
# -----------------------------------------------
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# -----------------------------------------------
# Frontend URL (CORS & Sanctum)
# -----------------------------------------------
FRONTEND_URL=http://localhost:5173
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:3000

# -----------------------------------------------
# Cache / Queue
# -----------------------------------------------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

# -----------------------------------------------
# Mail — gunakan Mailtrap / Mailpit untuk development
# -----------------------------------------------
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@restosaas.id"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------
# Super Admin — ubah sebelum production!
# -----------------------------------------------
SUPERADMIN_NAME="Super Administrator"
SUPERADMIN_EMAIL=superadmin@restosaas.id
SUPERADMIN_PASSWORD=GantiPasswordIni!

# Midtrans
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_IS_SANITIZED=true
MIDTRANS_IS_3DS=true
