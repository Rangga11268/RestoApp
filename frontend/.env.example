# Salin file ini ke .env lalu sesuaikan nilainya

# URL yang di-embed ke dalam QR Code meja.
# Harus bisa diakses oleh HP yang scan QR (bukan localhost).
#
# Development lokal (WiFi): gunakan IP jaringan kamu (cek dari output `npm run dev -- --host`)
# VITE_APP_URL=http://192.168.x.x:5173
#
# Production: ganti ke domain sebenarnya
# VITE_APP_URL=https://yourdomain.com
VITE_APP_URL=http://localhost:5173
